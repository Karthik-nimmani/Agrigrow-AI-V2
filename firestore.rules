rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AGRI-GROW AI SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model. Every piece of data in the system
     * is explicitly linked to a specific user via a hierarchical path and denormalized 
     * ownership fields (userId).
     * 
     * DATA STRUCTURE:
     * All application data is nested under the top-level /users/{userId} collection. 
     * FarmFields are subcollections of a User, and all analytical data (Yield, Soil, 
     * Weather, Diseases) are nested as subcollections under specific FarmFields.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Every document (even deeply nested ones) is expected 
     *    to contain a 'userId' field matching the owner. This allows rules to verify 
     *    access without expensive get() calls to parent documents.
     * 2. Strict Path-to-Data Consistency: During 'create' operations, we enforce that 
     *    internal ID and userId fields match the URL parameters.
     * 3. Immutability: Critical relational fields (userId, farmFieldId) are made 
     *    immutable during 'update' operations to prevent data being "moved" between owners.
     * 4. Private by Default: No data is publicly readable or listable. Only the 
     *    authenticated owner can access their own data tree.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the request is coming from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document already exists (for updates/deletes). */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the top-level User Profile.
     * @path /users/{userId}
     * @allow Authenticated user (create) where doc ID matches their UID.
     * @deny User B trying to (get) User A's profile.
     * @principle Ownership and Self-Creation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for Farm Fields belonging to a user.
     * @path /users/{userId}/farmFields/{farmFieldId}
     * @allow Owner (create) a field with valid userId and farmFieldId in the data.
     * @deny Owner (update) attempting to change the userId to a different user.
     * @principle Relational integrity and ownership enforcement.
     */
    match /users/{userId}/farmFields/{farmFieldId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) 
        && request.resource.data.userId == userId 
        && request.resource.data.id == farmFieldId;
      allow update: if isExistingOwner(userId) 
        && request.resource.data.userId == resource.data.userId 
        && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      // --- FarmField Subcollections ---

      /**
       * @description Historical yield data for a field.
       * @path /users/{userId}/farmFields/{farmFieldId}/yieldHistory/{id}
       * @allow Owner (list) yield history for their own field.
       * @deny User A (create) yield history under User B's field path.
       * @principle Path-based and denormalized field authorization.
       */
      match /yieldHistory/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId 
          && request.resource.data.farmFieldId == farmFieldId 
          && request.resource.data.id == id;
        allow update: if isExistingOwner(userId) 
          && request.resource.data.userId == resource.data.userId 
          && request.resource.data.farmFieldId == resource.data.farmFieldId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description AI-generated yield predictions.
       * @path /users/{userId}/farmFields/{farmFieldId}/yieldForecasts/{id}
       * @allow Owner (get) a specific forecast.
       * @principle Secure access to generated insights.
       */
      match /yieldForecasts/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId 
          && request.resource.data.farmFieldId == farmFieldId 
          && request.resource.data.id == id;
        allow update: if isExistingOwner(userId) 
          && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Weather data snapshots for the field location.
       * @path /users/{userId}/farmFields/{farmFieldId}/meteorologicalData/{id}
       * @allow Owner (list) weather history for their field.
       * @principle Scoped subcollection access.
       */
      match /meteorologicalData/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId 
          && request.resource.data.farmFieldId == farmFieldId 
          && request.resource.data.id == id;
        allow update: if isExistingOwner(userId) 
          && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Processed soil lab reports.
       * @path /users/{userId}/farmFields/{farmFieldId}/soilReports/{id}
       * @allow Owner (create) a report after processing a scan.
       * @principle Data consistency between path and document body.
       */
      match /soilReports/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId 
          && request.resource.data.farmFieldId == farmFieldId 
          && request.resource.data.id == id;
        allow update: if isExistingOwner(userId) 
          && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description AI findings on plant health and disease.
       * @path /users/{userId}/farmFields/{farmFieldId}/diseaseDetectionReports/{id}
       * @allow Owner (delete) an old detection report.
       * @principle Ownership verification for destructive operations.
       */
      match /diseaseDetectionReports/{id} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId 
          && request.resource.data.farmFieldId == farmFieldId 
          && request.resource.data.id == id;
        allow update: if isExistingOwner(userId) 
          && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}